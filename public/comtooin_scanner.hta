<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta charset="UTF-8">
    <title>COMTOOIN PC Asset Manager - CUSTOMER_NAME_PLACEHOLDER</title>
    
    <hta:application 
        id="comtooinApp"
        applicationname="ComtooinAssetManager"
        border="thin"
        caption="yes"
        showintaskbar="yes"
        singleinstance="yes"
        sysmenu="yes"
        windowstate="normal"
        scroll="no"
    />
    
    <style>
        body { 
            font-family: 'Malgun Gothic', sans-serif; 
            background-color: #f8fafc; 
            color: #0f172a; 
            margin: 0; 
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            overflow: hidden;
        }
        .container { 
            background: #ffffff; 
            padding: 20px 25px; 
            border-radius: 16px; 
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            width: 440px; 
            border: 1px solid #e2e8f0;
            text-align: center;
            box-sizing: border-box;
        }
        h1 { 
            font-size: 20px; 
            font-weight: 800;
            color: #1e3a8a; 
            margin: 0 0 8px 0;
        }
        .target-card {
            background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            padding: 8px 12px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
        }
        .target-label {
            font-size: 11px;
            font-weight: 800;
            color: #1e40af;
            letter-spacing: 0.3px;
        }
        .target-value {
            font-size: 13px;
            font-weight: 800;
            color: #1d4ed8;
        }
        p { 
            font-size: 12px; 
            color: #64748b; 
            line-height: 1.5; 
            margin: 0 0 15px 0; 
            text-align: left;
        }
        .input-group {
            text-align: left;
            margin-bottom: 12px;
        }
        .input-label {
            font-size: 11px;
            font-weight: 700;
            color: #475569;
            margin-bottom: 4px;
            display: block;
        }
        .input-control {
            width: 100%;
            height: 36px;
            padding: 0 10px;
            font-size: 12px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            box-sizing: border-box;
            font-family: inherit;
        }
        .input-control:focus {
            border-color: #2563eb;
            outline: none;
        }
        .status-box { 
            background: #f1f5f9; 
            border: 1px solid #e2e8f0; 
            padding: 10px 12px; 
            border-radius: 8px; 
            font-size: 12px;
            font-weight: 700; 
            color: #475569; 
            margin-top: 12px;
            margin-bottom: 15px; 
            min-height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-sizing: border-box;
        }
        .btn-group { 
            display: flex; 
            justify-content: center; 
        }
        button { 
            width: 100%; 
            height: 44px;
            font-size: 13px; 
            font-weight: 700; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            color: #ffffff; 
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            background-color: #2563eb; 
            transition: all 0.2s;
        }
        button:hover { 
            background-color: #1d4ed8;
        }
        button:disabled { 
            background-color: #cbd5e1 !important; 
            color: #94a3b8 !important;
            cursor: not-allowed; 
            box-shadow: none !important;
        }
    </style>
    
    <script>
        window.resizeTo(520, 580);


        var shell = new ActiveXObject("WScript.Shell");
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var compName = shell.ExpandEnvironmentStrings("%COMPUTERNAME%");
        var tempDir = shell.ExpandEnvironmentStrings("%TEMP%"); 

        // 32в╣ёьіИ mshta.exe ьЎўЖ▓йВЌљВёювЈё 64в╣ёьіИ PowerShellВЮё ьўИВХюьЋўВЌг 64в╣ёьіИ ВєїьћёьіИВЏеВќ┤(Вўцьћ╝Віц вЊ▒)вЦ╝ ВіцВ║ћьЋа Вѕў ВъѕвЈёвАЮ Ж░ЋВаю
        var sysnativePS = shell.ExpandEnvironmentStrings("%windir%\\sysnative\\WindowsPowerShell\\v1.0\\powershell.exe");
        var psExe = fso.FileExists(sysnativePS) ? sysnativePS : "powershell";

        function updateStatus(text, color) {
            var box = document.getElementById("statusBox");
            box.innerText = text;
            if(color) box.style.color = color;
        }

        function toggleButtons(disabled) {
            document.getElementById("btnScan").disabled = disabled;
        }

        function runAssetScan() {
            var dept = document.getElementById("deptInput").value.replace(/^\s+|\s+$/g, "");
            var userName = document.getElementById("userNameInput").value.replace(/^\s+|\s+$/g, "");

            if (!dept) {
                alert("ВєїВєЇ вХђВёювЦ╝ ВъЁваЦьЋ┤ ВБ╝ВёИВџћ.");
                document.getElementById("deptInput").focus();
                return;
            }
            if (!userName) {
                alert("ВѓгВџЕВъљ ВЮ┤вдёВЮё ВъЁваЦьЋ┤ ВБ╝ВёИВџћ.");
                document.getElementById("userNameInput").focus();
                return;
            }

            toggleButtons(true);
            updateStatus("РџЎ№ИЈ PC ВаЋв│┤ вХёВёЮ в░Ј ВъљВѓ░ Вёюв▓ё вЊ▒вАЮ ВцЉ...", "#d97706");
            
            setTimeout(function() {
                try {
                    var psPath = tempDir + "\\ct_asset_scan.ps1";
                    var file = fso.CreateTextFile(psPath, true, true);
                    
                    // Supabase ВЌ░вЈЎВЌљ ьЋёВџћьЋю ВаЋв│┤ (вІцВџ┤вАювЊю ВІю ВъљвЈЎ В╣ўьЎўвље)
                    var supabaseUrl = "SUPABASE_URL_PLACEHOLDER";
                    var supabaseAnonKey = "SUPABASE_KEY_PLACEHOLDER";
                    var customerId = "CUSTOMER_ID_PLACEHOLDER";

                    // ВъЉВЮђ вћ░Вў┤ьЉю ВЮ┤ВіцВ╝ђВЮ┤ьћё
                    var escapedDept = dept.replace(/'/g, "''");
                    var escapedUserName = userName.replace(/'/g, "''");

                    var code = 
                        "$OS = Get-CimInstance Win32_OperatingSystem\r\n" +
                        "$CPU = Get-CimInstance Win32_Processor\r\n" +
                        "$CS = Get-CimInstance Win32_ComputerSystem\r\n" +
                        "$Board = Get-CimInstance Win32_BaseBoard\r\n" +
                        "$C_DriveDisk = ''\r\n" +
                        "$OtherDisks = @()\r\n" +
                        "try {\r\n" +
                        "    $C_Part = Get-CimInstance -Query \"ASSOCIATORS OF {Win32_LogicalDisk.DeviceID='C:'} WHERE AssocClass=Win32_LogicalDiskToPartition\"\r\n" +
                        "    $C_DiskIndex = $null\r\n" +
                        "    if ($C_Part) {\r\n" +
                        "        $C_DiskIndex = $C_Part[0].DiskIndex\r\n" +
                        "        $Disks = Get-CimInstance Win32_DiskDrive\r\n" +
                        "        $C_Drive = $Disks | Where-Object { $_.Index -eq $C_DiskIndex }\r\n" +
                        "        if ($C_Drive) {\r\n" +
                        "            $gb = [Math]::Round($C_Drive[0].Size / 1073741824)\r\n" +
                        "            if ($gb -eq 0) { $gb = [Math]::Round($C_Drive[0].Size / 1000000000) }\r\n" +
                        "            $C_DriveDisk = '[CвЊювЮ╝ВЮ┤вИї] ' + ($C_Drive[0].Model -replace [char]0, '').Trim() + ' (' + $gb + 'GB)'\r\n" +
                        "        }\r\n" +
                        "    }\r\n" +
                        "    $Disks = Get-CimInstance Win32_DiskDrive\r\n" +
                        "    foreach ($d in $Disks) {\r\n" +
                        "        if ($d.Size -gt 0 -and $d.Index -ne $C_DiskIndex) {\r\n" +
                        "            $gb = [Math]::Round($d.Size / 1073741824)\r\n" +
                        "            if ($gb -eq 0) { $gb = [Math]::Round($d.Size / 1000000000) }\r\n" +
                        "            $OtherDisks += (($d.Model -replace [char]0, '').Trim() + ' (' + $gb + 'GB)')\r\n" +
                        "        }\r\n" +
                        "    }\r\n" +
                        "} catch {\r\n" +
                        "    $Disks = Get-CimInstance Win32_DiskDrive\r\n" +
                        "    foreach ($d in $Disks) {\r\n" +
                        "        if ($d.Size -gt 0) {\r\n" +
                        "            $gb = [Math]::Round($d.Size / 1073741824)\r\n" +
                        "            if ($gb -eq 0) { $gb = [Math]::Round($d.Size / 1000000000) }\r\n" +
                        "            $OtherDisks += (($d.Model -replace [char]0, '').Trim() + ' (' + $gb + 'GB)')\r\n" +
                        "        }\r\n" +
                        "    }\r\n" +
                        "}\r\n" +
                        "if ($C_DriveDisk) { $DiskList = @($C_DriveDisk) + $OtherDisks } else { $DiskList = $OtherDisks }\r\n" +
                        "$StorageStr = $DiskList -join ', '\r\n" +
                        "$IP = (Get-NetRoute -DestinationPrefix '0.0.0.0/0' 2>$null | Get-NetIPInterface | Get-NetIPAddress -AddressFamily IPv4 | Select-Object -First 1).IPAddress\r\n" +
                        "if (-not $IP) { $IP = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -notlike '127*' } | Select-Object -First 1).IPAddress }\r\n" +
                        "$IP = ($IP -replace [char]0, '').Trim()\r\n" +
                        "$GPUs = Get-CimInstance Win32_VideoController\r\n" +
                        "$RealGPUs = $GPUs | Where-Object { $_.Name -notmatch '(?i)virtual|indirect|mirror|render|rdp|remote' }\r\n" +
                        "if ($RealGPUs) { $GPU = ($RealGPUs.Name) -join ', ' } else { $GPU = ($GPUs.Name) -join ', ' }\r\n" +
                        "$GPU = ($GPU -replace [char]0, '').Trim()\r\n" +
                        "\r\n" +
                        "$MemChips = Get-CimInstance Win32_PhysicalMemory\r\n" +
                        "$TypeNum = ($MemChips | Select-Object -First 1).SMBIOSMemoryType\r\n" +
                        "$Speed = ($MemChips | Select-Object -First 1).Speed\r\n" +
                        "$DDR = 'DDR'\r\n" +
                        "if ($TypeNum -eq 24) { $DDR = 'DDR3' }\r\n" +
                        "elseif ($TypeNum -eq 26) { $DDR = 'DDR4' }\r\n" +
                        "elseif ($TypeNum -eq 34) { $DDR = 'DDR5' }\r\n" +
                        "else {\r\n" +
                        "    if ($Speed -ge 4800) { $DDR = 'DDR5' }\r\n" +
                        "    elif ($Speed -ge 2133 -and $Speed -lt 4800) { $DDR = 'DDR4' }\r\n" +
                        "    elif ($Speed -ge 800 -and $Speed -lt 2133) { $DDR = 'DDR3' }\r\n" +
                        "    else { $DDR = 'DDR2' }\r\n" +
                        "}\r\n" +
                        "$RAM_Total = [Math]::Round($CS.TotalPhysicalMemory / 1GB)\r\n" +
                        "$RAMStr = (($DDR + ' ' + $RAM_Total.ToString() + 'GB') -replace [char]0, '').Trim()\r\n" +
                        "$OSName = (($OS.Caption + ' (' + $OS.OSArchitecture + ')') -replace [char]0, '').Trim()\r\n" +
                        "$CPUName = ($CPU.Name -replace [char]0, '').Trim()\r\n" +
                        "$MBName = (($Board.Manufacturer + ' ' + $Board.Product) -replace [char]0, '').Trim()\r\n" +
                        "\r\n" +
                        "# 2. ВєїьћёьіИВЏеВќ┤ ВѕўВДЉ\r\n" +
                        "$R64 = 'HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'\r\n" +
                        "$R32 = 'HKLM:\\Software\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'\r\n" +
                        "$RUser = 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'\r\n" +
                        "$RC2R = 'HKLM:\\SOFTWARE\\Microsoft\\Office\\ClickToRun\\REGISTRY\\MACHINE\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'\r\n" +
                        "$Apps = Get-ItemProperty -Path $R64, $R32, $RUser, $RC2R 2>$null | Where-Object { $_.DisplayName -and ( ($_.SystemComponent -ne 1 -and $_.ParentKeyName -eq $null) -or ($_.DisplayName -match '(?i)Office|365|Hancom|ьЋюВ╗┤') ) }\r\n" +
                        "$Clean = $Apps | Where-Object {\r\n" +
                        "    $_.DisplayName -notmatch 'Security Update|Update for|KB[0-9]{6}|KB [0-9]{6}' -and\r\n" +
                        "    $_.DisplayName -notmatch 'Language Pack|Language Experience Pack' -and\r\n" +
                        "    $_.DisplayName -notmatch 'Visual C\\+\\+' -and\r\n" +
                        "    $_.DisplayName -notmatch 'Microsoft .NET|Targeting Pack' -and\r\n" +
                        "    $_.DisplayName -notmatch 'AhnLab Safe Transaction|IPinside|AnySign|TouchEn|INCAInternet|VoiceEye'\r\n" +
                        "} | Sort-Object DisplayName -Unique\r\n" + 
                        "$Rows = @(foreach ($a in $Clean) {\r\n" +
                        "    [PSCustomObject]@{\r\n" +
                        "        'program_name' = (($a.DisplayName -replace [char]0, '').Trim())\r\n" +
                        "        'program_version' = (($a.DisplayVersion -replace [char]0, '').Trim())\r\n" +
                        "        'publisher' = (($a.Publisher -replace [char]0, '').Trim())\r\n" +
                        "    }\r\n" +
                        "})\r\n" +
                        "$WordPath = (Get-ItemProperty 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\Winword.exe' -ErrorAction SilentlyContinue).'(default)'\r\n" +
                        "if (-not $WordPath -or -not (Test-Path $WordPath)) { $WordPath = \"$env:ProgramFiles\\Microsoft Office\\root\\Office16\\WINWORD.EXE\" }\r\n" +
                        "if (Test-Path $WordPath) {\r\n" +
                        "    if (-not ($Rows | Where-Object { $_.program_name -match '(?i)Office|365' })) {\r\n" +
                        "        $Ver = (Get-Item $WordPath).VersionInfo.ProductVersion\r\n" +
                        "        $Rows += [PSCustomObject]@{ 'program_name' = 'Microsoft Office LTSC / 365 (Absolute)'; 'program_version' = (($Ver -replace [char]0, '').Trim()); 'publisher' = 'Microsoft Corporation' }\r\n" +
                        "    }\r\n" +
                        "}\r\n" +
                        "\r\n" +
                        "# 3. в░▒ВЌЁВџЕ вАюВ╗г CSV ВЃЮВё▒\r\n" +
                        "$HwObj = [PSCustomObject]@{\r\n" +
                        "    'В╗┤ьЊеьё░ВЮ┤вдё' = $env:COMPUTERNAME\r\n" +
                        "    'вХђВёю' = '" + escapedDept + "'\r\n" +
                        "    'ВѓгВџЕВъљВЮ┤вдё' = '" + escapedUserName + "'\r\n" +
                        "    'IPВБ╝Вєї' = $IP\r\n" +
                        "    'Вџ┤ВўЂВ▓┤Ваю' = $OSName\r\n" +
                        "    'ьћёвАюВёИВёю' = $CPUName\r\n" +
                        "    'вЕћВЮИв│┤вЊю' = $MBName\r\n" +
                        "    'вЕћвфевдг' = $RAMStr\r\n" +
                        "    'ЖиИвъўьћйВ╣┤вЊю' = $GPU\r\n" +
                        "    'ВађВъЦВъЦВ╣ў' = $StorageStr\r\n" +
                        "}\r\n" +
                        "$HwObj | Export-Csv -Path ('.\\PC_SPEC_' + $env:COMPUTERNAME + '.csv') -NoTypeInformation -Encoding Default\r\n" +
                        "\r\n" +
                        "$SwCsvRows = @(foreach ($r in $Rows) {\r\n" +
                        "    [PSCustomObject]@{\r\n" +
                        "        'В╗┤ьЊеьё░ВЮ┤вдё' = $env:COMPUTERNAME\r\n" +
                        "        'вХђВёю' = '" + escapedDept + "'\r\n" +
                        "        'ВѓгВџЕВъљВЮ┤вдё' = '" + escapedUserName + "'\r\n" +
                        "        'ьћёвАюЖиИвъевфЁ' = $r.program_name\r\n" +
                        "        'ьћёвАюЖиИвъев▓ёВаё' = $r.program_version\r\n" +
                        "        'Ж│хЖИЅВъљ' = $r.publisher\r\n" +
                        "    }\r\n" +
                        "})\r\n" +
                        "if ($SwCsvRows.Count -gt 0) {\r\n" +
                        "    $SwCsvRows | Export-Csv -Path ('.\\SW_LIST_' + $env:COMPUTERNAME + '.csv') -NoTypeInformation -Encoding Default\r\n" +
                        "} else {\r\n" +
                        "    $Empty = [PSCustomObject]@{ 'В╗┤ьЊеьё░ВЮ┤вдё' = $env:COMPUTERNAME; 'вХђВёю' = '" + escapedDept + "'; 'ВѓгВџЕВъљВЮ┤вдё' = '" + escapedUserName + "'; 'ьћёвАюЖиИвъевфЁ' = 'ВёцВ╣ўвљю ьћёвАюЖиИвъе ВЌєВЮї'; 'ьћёвАюЖиИвъев▓ёВаё' = ''; 'Ж│хЖИЅВъљ' = '' }\r\n" +
                        "    $Empty | Export-Csv -Path ('.\\SW_LIST_' + $env:COMPUTERNAME + '.csv') -NoTypeInformation -Encoding Default\r\n" +
                        "}\r\n" +
                        "\r\n" +
                        "# 4. Supabase DB RPC вІцВЮ┤ваЅьіИ ВъљвЈЎ ВаёВєА\r\n" +
                        "$Payload = @{\r\n" +
                        "    p_customer_id = '" + customerId + "'\r\n" +
                        "    p_computer_name = $env:COMPUTERNAME\r\n" +
                        "    p_department = '" + escapedDept + "'\r\n" +
                        "    p_user_name = '" + escapedUserName + "'\r\n" +
                        "    p_ip_address = $IP\r\n" +
                        "    p_os = $OSName\r\n" +
                        "    p_processor = $CPUName\r\n" +
                        "    p_motherboard = $MBName\r\n" +
                        "    p_memory = $RAMStr\r\n" +
                        "    p_graphic_card = $GPU\r\n" +
                        "    p_storage = $StorageStr\r\n" +
                        "    p_software = $Rows\r\n" +
                        "} | ConvertTo-Json -Depth 5 -Compress\r\n" +
                        "\r\n" +
                        "$Headers = @{\r\n" +
                        "    'apikey' = '" + supabaseAnonKey + "'\r\n" +
                        "    'Authorization' = 'Bearer " + supabaseAnonKey + "'\r\n" +
                        "    'Content-Type' = 'application/json; charset=utf-8'\r\n" +
                        "    'Prefer' = 'return=minimal'\r\n" +
                        "}\r\n" +
                        "\r\n" +
                        "$BodyBytes = [System.Text.Encoding]::UTF8.GetBytes($Payload)\r\n" +
                        "\r\n" +
                        "try {\r\n" +
                        "    $res = Invoke-RestMethod -Uri '" + supabaseUrl + "/rest/v1/rpc/sync_pc_asset' -Method Post -Headers $Headers -Body $BodyBytes -ErrorAction Stop\r\n" +
                        "    Write-Output 'SUCCESS'\r\n" +
                        "} catch {\r\n" +
                        "    $msg = $_.Exception.Message\r\n" +
                        "    if ($_.Exception.Response) {\r\n" +
                        "        $stream = $_.Exception.Response.GetResponseStream()\r\n" +
                        "        if ($stream) {\r\n" +
                        "            $reader = New-Object System.IO.StreamReader($stream)\r\n" +
                        "            $msg = $reader.ReadToEnd()\r\n" +
                        "        }\r\n" +
                        "    }\r\n" +
                        "    Write-Error $msg\r\n" +
                        "}\r\n";
                         
                    file.Write(code);
                    file.Close();
                    
                    // ВІцьќЅ ьЏё Ж▓░Ж│╝ В║АВ▓ў
                    var exec = shell.Exec(psExe + " -NoProfile -ExecutionPolicy Bypass -File \"" + psPath + "\"");
                    var output = exec.StdOut.ReadAll();
                    var error = exec.StdErr.ReadAll();
                    
                    if (fso.FileExists(psPath)) fso.DeleteFile(psPath);

                    if (output.indexOf("SUCCESS") !== -1) {
                        updateStatus("РюЁ ВА░Вѓг ВЎёвБї в░Ј ВъљВѓ░ Вёюв▓ё ВаёВєА ВЎёвБї!", "#059669");
                        alert("Вё▒Ж│хВаЂВю╝вАю Вёюв▓ё ВаёВєА в░Ј ВъљВѓ░ вЊ▒вАЮВЮ┤ ВЎёвБївљўВЌѕВіхвІѕвІц!\n(в░▒ВЌЁВџЕ ьїїВЮ╝вЈё ьўёВъг ьЈ┤вЇћВЌљ PC_SPEC_" + compName + ".csv / SW_LIST_" + compName + ".csv вАю ВађВъЦвљўВЌѕВіхвІѕвІц.)");
                    } else {
                        updateStatus("РЮї Вёюв▓ё ВаёВєА ВІцьїе (вАюВ╗г ВађВъЦВЮђ ВЎёвБї)", "#d97706");
                        alert("Вёюв▓ё ВаёВєА ВцЉ ВўцвЦўЖ░ђ в░юВЃЮьќѕВіхвІѕвІц.\n(вАюВ╗г в░▒ВЌЁ ьїїВЮ╝ВЮђ ьўёВъг ьЈ┤вЇћВЌљ ВаЋВЃЂ ВЃЮВё▒вљўВЌѕВіхвІѕвІц.)\n\nВўцвЦў вѓ┤ВџЕ: " + error);
                    }
                } catch(e) {
                    updateStatus("РЮї ВА░Вѓг ВцЉ ВЌљвЪгЖ░ђ в░юВЃЮьќѕВіхвІѕвІц.", "#dc2626");
                    alert("ВўцвЦў вѓ┤ВџЕ: " + e.message);
                } finally {
                    toggleButtons(false);
                }
            }, 100);
        }
    </script>
</head>
<body>
    <div class="container">
        <h1>­Ъњ╗ В╗┤ьѕгВЮИ PC ВъљВѓ░ ВА░Вѓг ВІюВіцьЁю</h1>
        <p>в│И ьћёвАюЖиИвъеВЮђ Ві╣ВЮИвљю IT ВъљВѓ░ ВѕўВДЉ вЈёЖхгВъЁвІѕвІц. PC ВѓгВќЉ в░Ј ВёцВ╣ў ВєїьћёьіИВЏеВќ┤ вфЕвАЮВЮё вХёВёЮьЋўВЌг ВъљВѓ░ Ж┤ђвдг Вёюв▓ёВЌљ ВЋѕВаёьЋўЖ▓ї вЊ▒вАЮьЋЕвІѕвІц.</p>
        
        <div class="target-card">
            <span class="target-label">ВЮИВдЮ вїђВЃЂ Ж│аЖ░ЮВѓг</span>
            <span class="target-value">CUSTOMER_NAME_PLACEHOLDER</span>
        </div>
        
        <div class="input-group">
            <span class="input-label">ВєїВєЇ вХђВёю</span>
            <input type="text" id="deptInput" class="input-control" placeholder="Вўѕ: Ж┤ђвдгвХђ, Ж░юв░юьїђ" />
        </div>
        <div class="input-group">
            <span class="input-label">ВѓгВџЕВъљ ВЮ┤вдё</span>
            <input type="text" id="userNameInput" class="input-control" placeholder="Вўѕ: ьЎЇЖИИвЈЎ" />
        </div>

        <div class="status-box" id="statusBox">вїђЖИ░ ВцЉ... (вХђВёюВЎђ ВЮ┤вдёВЮё ВъЁваЦ ьЏё ВІюВъЉьЋўВёИВџћ)</div>
        
        <div class="btn-group">
            <button id="btnScan" onclick="runAssetScan()">РџЎ№ИЈ PC ВъљВѓ░ ВА░Вѓг в░Ј вЊ▒вАЮ ВІюВъЉ</button>
        </div>
    </div>
</body>
</html>
